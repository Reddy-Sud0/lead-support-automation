    {
      "parameters": {
        "jsCode": "// ─── DAILY DIGEST AGGREGATION — reads exact Google Sheets column names ───\n// Actual columns: valid, idempotencyKey, name, email, company,\n//                 message, urgency, product, receivedAt, companySource\n\nconst items = $input.all();\nconst today = new Date().toISOString().split('T')[0];\n\n// Log first row so you can verify in browser console\nconst sample = items[0]?.json || {};\nconsole.log('KEYS:', JSON.stringify(Object.keys(sample)));\nconsole.log('SAMPLE ROW:', JSON.stringify(sample));\n\n// Map using EXACT lowercase column names from Google Sheets\nconst allRows = items\n  .map(i => i.json)\n  .filter(r =>\n    r.name &&\n    r.name !== 'name' &&        // skip header row if present\n    r.email &&\n    r.receivedAt &&\n    r.valid === true || r.valid === 'true'  // only valid leads\n  );\n\n// Filter to today\nconst todayLeads = allRows.filter(r =>\n  String(r.receivedAt).startsWith(today)\n);\n\n// Fallback to all rows if no today leads (testing)\nconst workingLeads = todayLeads.length > 0 ? todayLeads : allRows;\n\n// Count by urgency using exact column name: urgency\nconst byUrgency = {};\nworkingLeads.forEach(r => {\n  const u = String(r.urgency || 'unknown').toLowerCase().trim();\n  byUrgency[u] = (byUrgency[u] || 0) + 1;\n});\n\n// Count by product using exact column name: product\nconst byProduct = {};\nworkingLeads.forEach(r => {\n  const p = String(r.product || 'unknown').trim();\n  byProduct[p] = (byProduct[p] || 0) + 1;\n});\n\n// Top 5 sorted by receivedAt descending\nconst top5 = [...workingLeads]\n  .sort((a, b) => new Date(b.receivedAt) - new Date(a.receivedAt))\n  .slice(0, 5)\n  .map(r => ({\n    name:       String(r.name || ''),\n    email:      String(r.email || ''),\n    company:    String(r.company || ''),\n    product:    String(r.product || ''),\n    urgency:    String(r.urgency || ''),\n    receivedAt: String(r.receivedAt || '')\n  }));\n\nconsole.log('totalLeads:', workingLeads.length);\nconsole.log('byUrgency:', JSON.stringify(byUrgency));\nconsole.log('byProduct:', JSON.stringify(byProduct));\n\nreturn [{\n  json: {\n    date:            today,\n    totalLeads:      workingLeads.length,\n    todayOnly:       todayLeads.length,\n    allLeads:        allRows.length,\n    byUrgency,\n    byProduct,\n    top5RecentLeads: top5\n  }\n}];"
      },
