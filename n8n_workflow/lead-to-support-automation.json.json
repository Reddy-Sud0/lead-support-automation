      "parameters": {
        "jsCode": "// ─── ENRICH LEAD ───\nconst item = $input.first().json;\n\nlet company = item.company;\nlet companySource = 'provided';\n\nif (!company || company === '') {\n  // Infer from email domain\n  const domain = item.email.split('@')[1] || '';\n  const domainWithoutTld = domain.split('.')[0] || '';\n\n  // Skip generic free email providers\n  const freeProviders = ['gmail', 'yahoo', 'hotmail', 'outlook', 'icloud', 'aol', 'protonmail', 'zoho', 'mail', 'live', 'msn'];\n  if (freeProviders.includes(domainWithoutTld.toLowerCase())) {\n    company = 'Individual / Unknown';\n    companySource = 'inferred-free-email';\n  } else {\n    // Capitalize domain name as company\n    company = domainWithoutTld.charAt(0).toUpperCase() + domainWithoutTld.slice(1);\n    companySource = `inferred-from-domain:${domain}`;\n  }\n}\n\nreturn [{\n  json: {\n    ...item,\n    company,\n    companySource\n  }\n}];\n"
      },
