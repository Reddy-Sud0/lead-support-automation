        "jsCode": "// ─── BUILD DIGEST EMAIL HTML ───\nconst d = $input.first().json;\n\nconst urgencyRows = Object.entries(d.byUrgency)\n  .map(([k,v]) => `<tr><td style=\"padding:6px 12px;border:1px solid #ddd\">${k}</td><td style=\"padding:6px 12px;border:1px solid #ddd;text-align:center\">${v}</td></tr>`)\n  .join('');\n\nconst productRows = Object.entries(d.byProduct)\n  .map(([k,v]) => `<tr><td style=\"padding:6px 12px;border:1px solid #ddd\">${k}</td><td style=\"padding:6px 12px;border:1px solid #ddd;text-align:center\">${v}</td></tr>`)\n  .join('');\n\nconst top5Rows = (d.top5RecentLeads || []).map(l =>\n  `<tr>\n    <td style=\"padding:6px 12px;border:1px solid #ddd\">${l.name}</td>\n    <td style=\"padding:6px 12px;border:1px solid #ddd\">${l.email}</td>\n    <td style=\"padding:6px 12px;border:1px solid #ddd\">${l.company}</td>\n    <td style=\"padding:6px 12px;border:1px solid #ddd\">${l.product}</td>\n    <td style=\"padding:6px 12px;border:1px solid #ddd\"><span style=\"color:${l.urgency==='high'?'#e53e3e':'#38a169'};font-weight:bold\">${l.urgency}</span></td>\n  </tr>`\n).join('');\n\nconst html = `\n<!DOCTYPE html><html><body style=\"font-family:Arial,sans-serif;color:#333;max-width:700px;margin:auto;padding:20px\">\n<h2 style=\"color:#4A90D9\">📊 Daily Lead Digest — ${d.date}</h2>\n<p>Total leads today: <strong>${d.totalLeads}</strong></p>\n\n<h3>By Urgency</h3>\n<table style=\"border-collapse:collapse;width:100%\">\n  <tr style=\"background:#f0f4ff\"><th style=\"padding:8px 12px;border:1px solid #ddd;text-align:left\">Urgency</th><th style=\"padding:8px 12px;border:1px solid #ddd\">Count</th></tr>\n  ${urgencyRows}\n</table>\n\n<h3 style=\"margin-top:20px\">By Product</h3>\n<table style=\"border-collapse:collapse;width:100%\">\n  <tr style=\"background:#f0f4ff\"><th style=\"padding:8px 12px;border:1px solid #ddd;text-align:left\">Product</th><th style=\"padding:8px 12px;border:1px solid #ddd\">Count</th></tr>\n  ${productRows}\n</table>\n\n<h3 style=\"margin-top:20px\">Top 5 Recent Leads</h3>\n<table style=\"border-collapse:collapse;width:100%\">\n  <tr style=\"background:#f0f4ff\">\n    <th style=\"padding:8px;border:1px solid #ddd\">Name</th>\n    <th style=\"padding:8px;border:1px solid #ddd\">Email</th>\n    <th style=\"padding:8px;border:1px solid #ddd\">Company</th>\n    <th style=\"padding:8px;border:1px solid #ddd\">Product</th>\n    <th style=\"padding:8px;border:1px solid #ddd\">Urgency</th>\n  </tr>\n  ${top5Rows}\n</table>\n\n<p style=\"margin-top:24px;color:#777;font-size:12px\">Generated automatically at 18:00. Lead-to-Support Automation.</p>\n</body></html>`;\n\nreturn [{ json: { ...d, emailHtml: html } }];\n"
      },
